# === PLANTILLA DE SECRETOS ===
# 1) Copia este fichero a  secrets.yaml  (en la misma carpeta que el .yaml del ESPHome).
# 2) Rellena con TUS valores.
# 3) secrets.yaml está en .gitignore y NUNCA se sube a GitHub.

wifi_ssid: "NOMBRE_DE_TU_WIFI"
wifi_password: "CONTRASENA_DE_TU_WIFI"

# Punto de acceso de rescate (si el WiFi falla, el ESP crea esta red)
ap_ssid: "Aerotermia Fallback"
ap_password: "una-contrasena-larga-de-respaldo"

# Clave de cifrado de la API de Home Assistant.
# Genérala con:   openssl rand -base64 32
api_key: "PEGA_AQUI_UNA_CLAVE_BASE64_DE_32_BYTES"

# Contraseña para actualizaciones OTA (elige una tú)
ota_password: "una-contrasena-para-ota"
